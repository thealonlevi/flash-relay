# Go build artifacts
*.o
*.a
*.so
*.test
*.out
/bin/
/dist/

# binaries built from gate/ (no extensions, hard to glob safely) — keep explicit
/gate/**/probe
/gate/**/baseline
/gate/**/loadgen

# profiling / measurement output
*.perf
perf.data*
*.prof
*.svg
# Keep curated gate results (SUMMARY.md, metrics.csv, env.txt, *_report.txt,
# b1 files) but never the bulky perf binaries or per-rep raw dumps.
gate/results/**/*.perfdata
gate/results/**/*_load_*.json
gate/results/**/*_perf_*.csv

# editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Go build artifacts
*.o
*.a
*.so
*.test
*.out
/bin/
/dist/

# Stray binaries from `go build` inside a cmd dir (same name as the dir). These
# anchored paths ignore the BINARY only — never the source dir / main.go.
# (Bug history: a broad `/gate/**/loadgen` here silently swallowed the
# gate/cmd/loadgen SOURCE directory so it never got committed.)
/research/gate/cmd/sink/sink
/research/gate/cmd/loadgen/loadgen
/research/gate/cmd/relay-uring/relay-uring
/research/gate/cmd/relay-netpoll/relay-netpoll

# profiling / measurement output
*.perf
perf.data*
*.prof
*.svg
# Keep curated gate results (SUMMARY.md, metrics.csv, env.txt, *_report.txt,
# b1 files) but never the bulky perf binaries or per-rep raw dumps.
research/gate/results/**/*.perfdata
research/gate/results/**/*_load_*.json
research/gate/results/**/*_perf_*.csv

# editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# optimizer runtime state (champion, logs, history) — not committed
research/optimizer/results/
research/gate/results/**/*.data
research/gate/results/**/*.load.json

# local Claude Code settings (never commit — machine/run-specific)
.claude/settings.local.json

# optimizer fast-validation override (never committed)
research/optimizer/config.local
